{
  "name": "antigravity-backend",
  "version": "1.0.0",
  "description": "Web scraping API for supermarket price comparison in Las Palmas de Gran Canaria",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "test:unit": "vitest run src",
    "test:integration": "vitest run src/**/*.integration.test.ts",
    "test:e2e": "playwright test tests/e2e/",
    "test": "vitest run"
  },
  "keywords": [
    "scraping",
    "supermarket",
    "playwright",
    "canarias"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "@prisma/client": "^6.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "node-cron": "^4.2.1",
    "playwright": "^1.50.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "user-agents": "^2.1.70",
    "uuid": "^11.0.5",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.5",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.19.2",
    "supertest": "^7.0.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.0.6"
  }
}
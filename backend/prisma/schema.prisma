generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(uuid())
  name         String
  supermarket  String
  category     String
  sku          String
  price        Float
  pricePerUnit Float
  unit         String
  image        String?
  url          String?
  taxType      String
  scrapedAt    DateTime @default(now())

  @@unique([supermarket, sku])
  @@index([name])
  @@index([category])
  @@index([supermarket])
}
